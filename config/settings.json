{
  "rag": {
    "pdf_paths": ["future-ready-talent-dataset"],
    "chunk_size": 400,
    "chunk_overlap": 60,
    "top_k": 6,
    "embedding_provider": "fastembed",
    "embedding_model": "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2",
    "vector_backend": "sqlite",
    "vector_store_path": "vector_store/vectors.db"
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-5-mini",
    "ollama_model": "llama3.1:8b",
    "base_url": "http://localhost:11434",
    "temperature": 0.0,
    "timeout_seconds": 20
  },
  "sql": {
    "backend": "sqlite",
    "connection": "data/future_ready_talent.db",
    "max_rows": 100,
    "timeout_seconds": 3
  },
  "logging": {
    "level": "INFO",
    "json": true
  }
}
