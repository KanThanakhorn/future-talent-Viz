FRT_DATABASE_PATH=data/future_ready_talent.db
FRT_DATASET_PATH=future-ready-talent-dataset
FRT_CHUNK_WORDS=400
FRT_CHUNK_OVERLAP=60
FRT_RETRIEVAL_LIMIT=6
# Optional: enables generated RAG answers. Without it, the API returns grounded extracts.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
FRT_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
FRT_RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
FRT_MODEL_CACHE_PATH=data/model-cache
FRT_RETRIEVAL_CANDIDATES=50
FRT_ENABLE_RERANKER=1
