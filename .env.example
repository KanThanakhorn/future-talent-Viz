# Never commit real keys.
FRT_DATABASE_PATH=data/future_ready_talent.db
FRT_DATASET_PATH=future-ready-talent-dataset
FRT_CHUNK_WORDS=400
FRT_RETRIEVAL_LIMIT=6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
FRT_RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
FRT_MODEL_CACHE_PATH=data/model-cache
FRT_RETRIEVAL_CANDIDATES=50
FRT_ENABLE_RERANKER=1

# New interface-driven RAG + MCP backend (optional overrides for config/settings.json).
FRT_CONFIG=config/settings.json
FRT_PDF_PATHS=future-ready-talent-dataset
FRT_VECTOR_STORE_PATH=vector_store/vectors.db
FRT_EMBEDDING_PROVIDER=fastembed
FRT_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
FRT_CHUNK_SIZE=400
FRT_CHUNK_OVERLAP=60
FRT_TOP_K=6
FRT_LLM_PROVIDER=openai
FRT_TEMPERATURE=0
